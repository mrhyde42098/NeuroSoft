# ============================================================
# .env.example — Configuración de NeuroSoft Backend
# ============================================================
# Copiar a `.env` y editar con valores reales antes de arrancar.
# NUNCA subir el .env real a git (está en .gitignore).
#
# Generar claves fuertes:
#     python -c "import secrets; print(secrets.token_urlsafe(48))"
#
# Los nombres de variables siguen el prefijo NEUROSOFT_ (configurado
# en app/core/config.py con pydantic-settings).
# ============================================================

# ── Entorno ─────────────────────────────────────────────────
# development | production | testing
NEUROSOFT_ENV=production

# ── Seguridad (OBLIGATORIAS en producción) ──────────────────
# JWT: mínimo 32 caracteres. El arranque aborta si falta.
NEUROSOFT_SECRET_KEY=REEMPLAZAR-CON-TOKEN-GENERADO-DE-AL-MENOS-48-CHARS

# Contraseña inicial del usuario admin (se crea en el primer arranque).
# Mínimo 8 caracteres. Cámbiela inmediatamente tras el primer login.
NEUROSOFT_ADMIN_PASSWORD=CAMBIAR-POR-UNA-CONTRASENA-FUERTE

# ── CORS ────────────────────────────────────────────────────
# Lista JSON de orígenes autorizados. En producción NO usar "*".
NEUROSOFT_CORS_ORIGINS=["https://neurosoft.midominio.co"]

# ── Rutas de datos ──────────────────────────────────────────
# Dentro del contenedor Docker, /app/data es el volumen persistente.
NEUROSOFT_DATA_DIR=/app/data
NEUROSOFT_DB_PATH=/app/data/neurosoft.db
NEUROSOFT_BAREMO_PATH=/app/data/BD_NEURO_MAESTRA.json
NEUROSOFT_REPORTS_DIR=/app/data/reports

# ── Observabilidad ──────────────────────────────────────────
NEUROSOFT_LOG_LEVEL=INFO
NEUROSOFT_EXPOSE_DOCS=0              # 1 para habilitar /docs y /redoc (no recomendado en prod)
NEUROSOFT_RATE_LIMIT_PER_MIN=120     # 0 para desactivar rate limit

# ── Marca clínica (personalización white-label) ────────────
NEUROSOFT_CLINICAL_BRAND=NeuroSoft
NEUROSOFT_CLINICAL_BRAND_SUBTITLE=Plataforma de evaluación neuropsicológica

# ── Límites de upload (defensa contra DoS / contenido malicioso) ─
NEUROSOFT_MAX_UPLOAD_BACKUP_MB=200
NEUROSOFT_MAX_UPLOAD_XLSM_MB=50
NEUROSOFT_MAX_FIRMA_KB=512

# ── SMTP (opcional — correos de recordatorio) ──────────────
# Dejar smtp_host vacío para deshabilitar la feature.
NEUROSOFT_SMTP_HOST=
NEUROSOFT_SMTP_PORT=587
NEUROSOFT_SMTP_USER=
NEUROSOFT_SMTP_PASSWORD=
NEUROSOFT_SMTP_FROM=
NEUROSOFT_SMTP_FROM_NAME=NeuroSoft
NEUROSOFT_SMTP_USE_TLS=1
NEUROSOFT_SMTP_USE_SSL=0
NEUROSOFT_SMTP_TIMEOUT=30

# ── Puerto externo de Docker Compose ────────────────────────
# (Este no lo lee la app; lo usa docker-compose.yml)
NEUROSOFT_PORT=8000
